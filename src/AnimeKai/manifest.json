{
  "id": "animekai",
  "name": "AnimeKai",
  "description": "AnimeKai is an online streaming provider for subbed/dubbes animes in English",
  "manifestURI": "https://raw.githubusercontent.com/kRYstall9/Seanime-streaming-providers/refs/heads/main/src/AnimeKai/manifest.json",
  "version": "1.2.0",
  "author": "kRYstall9",
  "type": "onlinestream-provider",
  "language": "typescript",
  "lang": "en",
  "payloadURI": "https://raw.githubusercontent.com/kRYstall9/Seanime-streaming-providers/refs/heads/main/src/AnimeKai/provider.ts",
  "userConfig": {
    "requiredConfig": false,
    "version": 1,
    "fields": [
      {
        "name": "baseUrl",
        "label": "Base URL",
        "type": "text",
        "default": "https://anikai.to"
      },
      {
        "name": "batchSize",
        "label": "Batch Size",
        "type": "number",
        "default": 50
      },
      {
        "name": "batchDelay",
        "label": "Batch Delay",
        "type": "number",
        "default": 500
      }
    ]
  }
}
